# Variables de entorno para PRODUCCIÓN
# Este archivo se carga automáticamente cuando VITE_MODE=production

# Forzar modo producción
VITE_MODE=production

# URL base de la API para producción
VITE_API_BASE_URL=https://isladominicana-pos-mobile-api.azurewebsites.net/api

# Configuración de producción
VITE_ENABLE_MOCK_DATA=false
VITE_LOG_LEVEL=error

# Configuración de la API
VITE_API_TIMEOUT=30000
VITE_API_MAX_RETRIES=3

# Configuración de seguridad para producción
VITE_STRICT_MODE=true
VITE_DISABLE_DEVTOOLS=true
