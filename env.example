# Variables de entorno para la aplicación
# Copia este archivo a .env y ajusta los valores según tu ambiente

# ========================================
# DESARROLLO (npm run dev)
# ========================================
# Ambiente
NODE_ENV=development

# URL base de la API para desarrollo
VITE_API_BASE_URL=http://localhost:3000/api

# Configuración de desarrollo
VITE_ENABLE_MOCK_DATA=true
VITE_LOG_LEVEL=debug

# Configuración de la API
VITE_API_TIMEOUT=30000
VITE_API_MAX_RETRIES=3

# ========================================
# PRODUCCIÓN (npm run prod)
# ========================================
# Para producción, crear archivo .env.production con:
# NODE_ENV=production
# VITE_API_BASE_URL=https://isladominicana-pos-mobile-api.azurewebsites.net/api
# VITE_ENABLE_MOCK_DATA=false
# VITE_LOG_LEVEL=error
